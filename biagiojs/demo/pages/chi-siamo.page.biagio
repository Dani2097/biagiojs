<component id="story" seo="1" conversion="0.5" cpu="2">
  <template>
    <section style="max-width:720px">
      <div style="color:var(--accent);font-weight:700;letter-spacing:.2em;font-size:12px;text-transform:uppercase">Dal 2019</div>
      <h1 style="font-size:clamp(30px,4.5vw,48px)">Corriamo anche noi.</h1>
      <p style="line-height:1.7;color:#3a3a48">VELOCE nasce a Milano da tre maratoneti stanchi di scegliere tra leggerezza e durata. Ogni modello viene testato per 1.000 km dai nostri atleti prima di arrivare in negozio.</p>
      <p style="line-height:1.7;color:#3a3a48">Questa pagina è scritta in <b>sintassi .biagio</b>: pesi business dichiarati come attributi, zero JavaScript da scrivere per le parti statiche.</p>
    </section>
  </template>
</component>

<component id="team-cta" conversion="0.9" interaction="0.5">
  <template>
    <section style="text-align:center">
      <button class="cta" id="join">Lavora con noi</button>
      <p id="join-status" style="color:var(--muted);font-size:13px;margin-top:10px"></p>
    </section>
  </template>
  <script hydrate>
    const btn = el.querySelector('#join');
    const st = el.querySelector('#join-status');
    st.textContent = 'isola idratata da sintassi .biagio ✓';
    btn.addEventListener('click', () => { btn.textContent = 'Candidatura inviata ✓'; btn.disabled = true; });
  </script>
</component>

<component id="footer" conversion="0.05">
