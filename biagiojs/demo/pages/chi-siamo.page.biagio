<component id="nav" seo="0.3" conversion="0.2" interaction="0.3">
  <template>
    <nav class="main"><span class="logo">VELO<span>CE</span></span><a href="/">AeroFoam X-1</a><a href="/collection/">Collezione</a><a href="/chi-siamo/">Chi siamo</a></nav>
