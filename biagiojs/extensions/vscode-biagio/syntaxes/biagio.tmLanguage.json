{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "biagio",
  "scopeName": "source.biagio",
  "patterns": [
    { "include": "#comments" },
    { "include": "#tags" }
  ],
  "repository": {
    "comments": {
      "patterns": [{ "name": "comment.block.html", "match": "<!--[\\s\\S]*?-->" }]
    },
    "tags": {
      "patterns": [
        {
          "name": "meta.tag.page.biagio",
          "begin": "(<)(page)\\b",
          "beginCaptures": { "1": { "name": "punctuation.definition.tag" }, "2": { "name": "entity.name.tag.page" } },
          "end": "/?>",
          "patterns": [{ "include": "#attributes" }]
        },
        {
          "name": "meta.tag.component.biagio",
          "begin": "(<)(component)\\b",
          "beginCaptures": { "1": { "name": "punctuation.definition.tag" }, "2": { "name": "entity.name.tag.component" } },
          "end": "(>)|(?=</component>)",
          "patterns": [{ "include": "#attributes" }]
        },
        {
          "name": "meta.tag.template.biagio",
          "begin": "(<)(template)\\b",
          "end": "(>)|(?=</template>)",
          "patterns": [{ "include": "text.html.basic" }]
        },
        {
          "name": "meta.tag.script.hydrate.biagio",
          "begin": "(<)(script)(?=[^>]*\\bhydrate\\b)",
          "end": "(>)|(?=</script>)",
          "patterns": [{ "include": "source.js" }]
        },
        {
          "name": "meta.tag.style.biagio",
          "begin": "(<)(style)\\b",
          "end": "(>)|(?=</style>)",
          "patterns": [{ "include": "source.css" }]
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "entity.other.attribute-name.biagio.weight",
          "match": "\\b(conversion|seo|interaction|cpu|memory|network)\\b"
        },
        {
          "name": "entity.other.attribute-name.biagio.hydrate",
          "match": "\\b(hydrate|client|props|consent|deps|id)\\b"
        },
        {
          "name": "string.quoted.double.html",
          "begin": "\"", "end": "\""
        },
        {
          "name": "string.quoted.single.html",
          "begin": "'", "end": "'"
        }
      ]
    }
  }
}
